---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import ClientRouter from "astro/components/ClientRouter.astro";
---

<html lang="es">
	<head>
		<!-- Google tag (gtag.js) -->
		<script
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-X9WVB5QDV8"
		></script>

		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}

			gtag("js", new Date());
			gtag("config", "G-X9WVB5QDV8");

			// Escuchamos el evento de navegación de Astro
			document.addEventListener("astro:page-load", () => {
				gtag("config", "G-X9WVB5QDV8", {
					page_path: window.location.pathname,
				});
			});
		</script>
		<BaseHead
			title="Servel Computadoras"
			description="Nos dedicamos a la reparación de equipos de cómputo, impresoras, redes y más en Playa del Carmen"
		/>
		<ClientRouter />
	</head>
	<body>
		<main class="max-w-[1650px] m-auto">
			<slot />
		</main>
	</body><Footer />
</html>
